@inproceedings{ashuach2024revs,
  title={{REVS}: Unlearning Sensitive Information in Language Models via Rank Editing in the Vocabulary Space},
  author={Ashuach, Tomer and Tutek, Martin and Belinkov, Yonatan},
  booktitle={Findings of the Association for Computational Linguistics: ACL 2025},
  year={2025},
  month={May},
  abbr={ACL Findings 2025},
  website={https://technion-cs-nlp.github.io/REVS/},
  url={https://technion-cs-nlp.github.io/REVS/},
  pdf={REVS__Unlearning_Sensitive_Information_in_Language_Models_via_Rank_Editing_in_the_Vocabulary_Space_ACL_2025.pdf},
