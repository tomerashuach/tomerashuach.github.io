@inproceedings{ashuach2026masked,
  title={Masked by Consensus: Disentangling Privileged Knowledge in LLM Correctness},
  author={Ashuach, Tomer and Ein-Dor, Liat and Gretz, Shai and Katz, Yoav and Belinkov, Yonatan},
  booktitle={Proceedings of the 64th Annual Meeting of the Association for Computational Linguistics: ACL 2026},
  year={2026},
  month={12},
  abbr={ACL 2026 (Oral)},
  website={https://technion-cs-nlp.github.io/Privileged-Knowledge/},
  url={https://tomerashuach.github.io/},
  pdf={Masked_by_Consensus__Disentangling_Privileged_Knowledge_in_LLM_Correctness.pdf},
  preview={pk.png},
  abstract={We explore whether large language models possess privileged internal knowledge about their own correctness, analogous to human introspection. By evaluating models on conflicting predictions, we discover that LLMs exhibit a domain-specific intuition for factual knowledge tasks that external observers cannot access.}
}

@inproceedings{ashuach2025crisp,
  title={{CRISP}: Persistent Concept Unlearning via Sparse Autoencoders},
  author={Ashuach, Tomer and Arad, Dana and Mueller, Aaron and Tutek, Martin and Belinkov, Yonatan},
  booktitle={Proceedings of the 64th Annual Meeting of the Association for Computational Linguistics: ACL 2026},
  year={2026},
  month={01},
  abbr={ACL 2026 (Oral)},
